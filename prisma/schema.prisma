generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Submission {
  id         String   @id @default(cuid())
  teamName   String
  dateTime   DateTime
  location   String
  category   String
  name       String
  memo       String?
  mediaUrls  String   // JSON stringified array of URLs
  isHidden   Boolean  @default(false)
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
}

model SystemSetting {
  id              String  @id @default("global")
  isUploadEnabled Boolean @default(true)
}
