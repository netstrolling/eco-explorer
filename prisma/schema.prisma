generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Event {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  startDate   DateTime
  endDate     DateTime
  guidePages  String       @default("[]")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id         String   @id @default(cuid())
  teamName   String
  dateTime   DateTime
  location   String
  category   String
  name       String
  memo       String?
  mediaUrls  String
  isHidden   Boolean  @default(false)
  lat        Float?
  lng        Float?
  uploaderIp String?
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id])
  createdAt  DateTime @default(now())
}

model SystemSetting {
  id              String  @id @default("global")
  isUploadEnabled Boolean @default(true)
}
